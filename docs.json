{
  "$schema": "https://squeditor.com/docs/docs.json",
  "theme": "almond",
  "name": "Squeditor Docs",
  "icons": {
    "library": "lucide"
  },
  "colors": {
    "primary": "#038677",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "fonts": {
    "family": "TASA Orbiter"
  },
  "favicon": "/favicon.svg",
  "banner": {
    "content": "🚀 Squeditor Beta is now live! See our [changelog](/changelog) for details.",
