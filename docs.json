  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "dropdowns": [
      {
        "dropdown": "Editor",
        "icon": "squirrel",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "editor/getting-started/introduction",
              "editor/getting-started/playground"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "editor/configuration/template",
              "editor/configuration/global-settings",
              "editor/configuration/theme-config",
              "editor/configuration/pages",
              "editor/configuration/sections-library"
            ]
          },
          {
            "group": "Components",
            "pages": [
              "editor/components/group-containers",
              "editor/components/controls",
              "editor/components/conditional-display",
              "editor/components/ai"
            ]
          }
        ]
      },
      {
        "dropdown": "Framework",
        "icon": "paw-print",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "framework/getting-started/introduction",
              "framework/getting-started/quickstart",
              "framework/getting-started/squeditor-config",
              "framework/getting-started/build-pipeline",
              "framework/getting-started/deployment"
            ]
          },
          {
            "group": "Architecture & Templating",
            "pages": [
              "framework/architecture-templating/folder-structure",
              "framework/architecture-templating/php-templating",
              "framework/architecture-templating/data-layer",
              "framework/architecture-templating/components-manifest",
              "framework/architecture-templating/editor-compatibility"
            ]
          },
          {
            "group": "Styling & Theming",
            "pages": [
              "framework/styling-frontend/tailwind-integration",
              "framework/styling-frontend/scss-architecture",
              "framework/styling-frontend/multi-theme"
            ]
          },
          {
            "group": "GSAP Animations",
            "pages": [
              "framework/gsap/general",
              "framework/gsap/timeline",
              "framework/gsap/keyframes",
              "framework/gsap/plugins",
              "framework/gsap/modules"
            ]
          },
          {
            "group": "Other",
            "pages": [
              "framework/license",
              "framework/contributing",
              "framework/changelog",
              "framework/feature-request",
              "framework/support"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Talk to us",
        "href": "mailto:hi@squeditor.com"
